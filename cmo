<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Referee Coach Pro v6.7</title>
    <style>
        :root { --main: #2c3e50; --teamA: #3498db; --teamB: #e74c3c; --common: #34495e; --bg: #ecf0f1; --success: #27ae60; --warning: #f39c12; }
        body { font-family: sans-serif; margin: 0; background: var(--bg); display: flex; flex-direction: column; height: 100vh; overflow: hidden; touch-action: none; }
        header { background: var(--main); color: white; padding: 5px; text-align: center; flex-shrink: 0; }
        
        .score-board { display: flex; justify-content: space-around; background: #34495e; padding: 5px; }
        .team-box { width: 48%; text-align: center; }
        .team-name { width: 90%; background: #2c3e50; border: 1px solid #5d6d7e; color: white; text-align: center; font-size: 0.9rem; padding: 4px; border-radius: 4px; margin-bottom: 5px; }
        
        .btn-row { display: flex; justify-content: center; gap: 2px; margin-bottom: 3px; }
        .btn-s { font-size: 0.7rem; padding: 6px 1px; border: none; border-radius: 3px; color: white; font-weight: bold; flex: 1; cursor: pointer; }
        .btn-minus { background: #555 !important; flex: 0.6; }
        .bg-A { background: var(--teamA); } .bg-B { background: var(--teamB); }
        .bg-adv { background: var(--warning); color: #fff; } /* Advボタン用の黄色 */

        .score-display { display: flex; justify-content: center; gap: 5px; color: white; font-size: 0.75rem; align-items: center; flex-wrap: wrap; }
        .total-pts { font-size: 1.3rem; font-weight: bold; color: #f1c40f; margin-left: 5px; }
        .stats-summary { font-size: 0.65rem; color: #bdc3c7; width: 100%; margin-top: 2px; line-height: 1.25; text-align: left; padding-left: 4px; }

        .timer-container { display: flex; justify-content: space-around; background: #000; color: #00ff00; font-family: monospace; padding: 6px 0; }
        .timer-val { font-size: 1.6rem; }
        .active-timer { color: #fff; text-shadow: 0 0 10px #3498db; }

        .phase-control { padding: 6px; background: #fff; border-bottom: 1px solid #ddd; }
        .btn-phase { width: 100%; padding: 10px; font-size: 1rem; border-radius: 6px; border: none; color: white; font-weight: bold; }

        /* アクションエリア: メモ構成をシンプルな3列に戻す */
        .action-area { padding: 6px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 6px; flex-shrink: 0; }
        .btn-memo { height: 45px; border: none; border-radius: 8px; color: white; font-weight: bold; font-size: 0.85rem; box-shadow: 0 3px #999; }

        .log-area { flex-grow: 1; overflow-y: auto; background: white; margin: 5px 10px; border-radius: 8px; padding: 5px; border: 1px solid #ddd; -webkit-overflow-scrolling: touch; font-size: 0.85rem; }
        .log-entry { border-bottom: 1px solid #eee; padding: 6px; display: flex; flex-direction: column; margin-bottom: 4px; border-radius: 4px; position: relative; }
        .log-A { border-left: 6px solid var(--teamA); background: #ebf5fb; }
        .log-B { border-left: 6px solid var(--teamB); background: #fdedec; }
        .log-C { border-left: 6px solid var(--common); background: #f4f6f7; }
        .log-img { max-width: 60%; border: 1px solid #ccc; margin-top: 5px; background: white; }
        
        .log-controls { position: absolute; right: 5px; top: 5px; display: flex; gap: 5px; }
        .btn-edit { background: #7f8c8d; color: white; border: none; border-radius: 4px; padding: 3px 6px; font-size: 0.65rem; }
        .btn-del { background: #e74c3c; color: white; border: none; border-radius: 4px; padding: 3px 6px; font-size: 0.65rem; }

        .save-footer { padding: 8px; display: flex; gap: 8px; background: #eee; }
        .btn-footer { flex: 1; padding: 10px; border-radius: 6px; border: none; color: white; font-weight: bold; font-size: 0.9rem; }

        /* キャンバス画面（下半分表示 50vh） */
        .modal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; flex-direction: column; z-index: 2000; }
        .canvas-modal { top: auto; bottom: 0; height: 50vh; box-shadow: 0 -5px 15px rgba(0,0,0,0.3); border-top: 3px solid var(--main); }
        #canvasHeader { background: #eee; padding: 6px 10px; display: flex; justify-content: space-between; align-items: center; flex-shrink: 0; }
        #drawingCanvas { flex-grow: 1; width: 100%; touch-action: none; background: #fff; }
        #backupModal { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: white; z-index: 3000; overflow-y: auto; padding: 20px; box-sizing: border-box; }
    </style>
</head>
<body>

<header>
    <div class="score-board">
        <div class="team-box">
            <input type="text" id="teamAName" class="team-name" value="TeamA">
            <div class="btn-row">
                <button class="btn-s bg-A" onclick="changeScore('A',5,'T')">T</button>
                <button class="btn-s bg-A" onclick="changeScore('A',2,'C')">C</button>
                <button class="btn-s bg-A" onclick="changeScore('A',7,'PT')">PT</button>
                <button class="btn-s bg-A" onclick="changeScore('A',3,'PG')">PG</button>
                <button class="btn-s bg-A" onclick="changeScore('A',3,'DG')">DG</button>
                <button class="btn-s btn-minus" onclick="changeScore('A',-1,'修正')">－</button>
            </div>
            <div class="btn-row">
                <button class="btn-s bg-A" onclick="openCanvasWithStat('A','PK')">PK</button>
                <button class="btn-s bg-A" onclick="openCanvasWithStat('A','FK')">FK</button>
                <button class="btn-s bg-A" onclick="openCanvasWithStat('A','SC')">SC</button>
                <button class="btn-s bg-A" onclick="openCanvasWithStat('A','LO')">LO</button>
                <button class="btn-s bg-adv" onclick="addDirectStat('A','Adv','アドバンテージオーバー')">Adv</button>
            </div>
            <div class="score-display">
                前:<span id="sA1">0</span> 後:<span id="sA2">0</span> <div class="total-pts" id="totalA">0</div>
                <div class="stats-summary">
                    前 PK:<span id="sA1_PK">0</span> FK:<span id="sA1_FK">0</span> SC:<span id="sA1_SC">0</span> LO:<span id="sA1_LO">0</span> Adv:<span id="sA1_Adv">0</span><br>
                    後 PK:<span id="sA2_PK">0</span> FK:<span id="sA2_FK">0</span> SC:<span id="sA2_SC">0</span> LO:<span id="sA2_LO">0</span> Adv:<span id="sA2_Adv">0</span>
                </div>
            </div>
        </div>
        <div style="color:white; align-self:center; font-weight:bold; margin:0 2px;">VS</div>
        <div class="team-box">
            <input type="text" id="teamBName" class="team-name" value="TeamB">
            <div class="btn-row">
                <button class="btn-s bg-B" onclick="changeScore('B',5,'T')">T</button>
                <button class="btn-s bg-B" onclick="changeScore('B',2,'C')">C</button>
                <button class="btn-s bg-B" onclick="changeScore('B',7,'PT')">PT</button>
                <button class="btn-s bg-B" onclick="changeScore('B',3,'PG')">PG</button>
                <button class="btn-s bg-B" onclick="changeScore('B',3,'DG')">DG</button>
                <button class="btn-s btn-minus" onclick="changeScore('B',-1,'修正')">－</button>
            </div>
            <div class="btn-row">
                <button class="btn-s bg-B" onclick="openCanvasWithStat('B','PK')">PK</button>
                <button class="btn-s bg-B" onclick="openCanvasWithStat('B','FK')">FK</button>
                <button class="btn-s bg-B" onclick="openCanvasWithStat('B','SC')">SC</button>
                <button class="btn-s bg-B" onclick="openCanvasWithStat('B','LO')">LO</button>
                <button class="btn-s bg-adv" onclick="addDirectStat('B','Adv','アドバンテージオーバー')">Adv</button>
            </div>
            <div class="score-display">
                前:<span id="sB1">0</span> 後:<span id="sB2">0</span> <div class="total-pts" id="totalB">0</div>
                <div class="stats-summary">
                    前 PK:<span id="sB1_PK">0</span> FK:<span id="sB1_FK">0</span> SC:<span id="sB1_SC">0</span> LO:<span id="sB1_LO">0</span> Adv:<span id="sB1_Adv">0</span><br>
                    後 PK:<span id="sB2_PK">0</span> FK:<span id="sB2_FK">0</span> SC:<span id="sB2_SC">0</span> LO:<span id="sB2_LO">0</span> Adv:<span id="sB2_Adv">0</span>
                </div>
            </div>
        </div>
    </div>
    <div class="timer-container">
        <div id="box1">前 <span class="timer-val" id="time1">00:00</span></div>
        <div id="box2">後 <span class="timer-val" id="time2">00:00</span></div>
    </div>
</header>

<div class="phase-control">
    <button id="mainBtn" class="btn-phase" style="background:var(--success)" onclick="handlePhase()">試合開始</button>
    <button id="nextBtn" class="btn-phase" style="background:var(--teamA); display:none;" onclick="location.reload()">次の試合へ</button>
</div>

<div class="action-area">
    <button class="btn-memo" style="background:var(--teamA);" onclick="openCanvas('A')">A メモ</button>
    <button class="btn-memo" style="background:var(--teamB);" onclick="openCanvas('B')">B メモ</button>
    <button class="btn-memo" style="background:var(--common);" onclick="openCanvas('C')">共通 メモ</button>
</div>

<div class="log-area" id="logArea"></div>

<div class="save-footer">
    <button onclick="downloadCSV()" style="background:var(--main);" class="btn-footer">CSV保存</button>
    <button onclick="showBackup()" style="background:#7f8c8d;" class="btn-footer">全データ救出</button>
</div>

<div id="canvasModal" class="modal canvas-modal">
    <div id="canvasHeader">
        <button onclick="closeCanvas()" style="padding:6px 12px;">戻る</button>
        <b id="canvasTitle">メモ</b>
        <div>
            <button onclick="clearCanvas()" style="padding:6px 12px; background:var(--teamB); color:white; border:none; border-radius:4px;">消去</button>
            <button onclick="saveCanvas()" id="saveBtn" style="padding:6px 12px; background:var(--success); color:white; border:none; border-radius:4px; margin-left:10px;">保存</button>
        </div>
    </div>
    <canvas id="drawingCanvas"></canvas>
</div>

<div id="backupModal" class="modal">
    <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:2px solid #333; padding-bottom:10px;">
        <h2>救出データ</h2><button onclick="document.getElementById('backupModal').style.display='none'" style="padding:10px;">閉じる</button>
    </div>
    <div id="backupContent"><textarea id="backupText" style="width:100%; height:100px;"></textarea><div id="backupImages"></div></div>
</div>

<script>
    let phase = 0, timerInterval, logs = [], t1 = 0, t2 = 0, startTimestamp;
    let scores = { A1:0, A2:0, B1:0, B2:0 };
    // スタッツオブジェクトにAdvを追加
    let stats = {
        A1: {PK:0, FK:0, SC:0, LO:0, Adv:0},
        A2: {PK:0, FK:0, SC:0, LO:0, Adv:0},
        B1: {PK:0, FK:0, SC:0, LO:0, Adv:0},
        B2: {PK:0, FK:0, SC:0, LO:0, Adv:0}
    };
    let currentMode = "C", pendingStat = null, editingLogId = null;

    function handlePhase() {
        const btn = document.getElementById('mainBtn');
        if (phase === 0) {
            startTimestamp = Date.now(); timerInterval = setInterval(updateTimer, 1000);
            phase = 1; btn.innerText = "HTへ"; btn.style.background = "#e67e22";
            document.getElementById('box1').classList.add('active-timer');
            addLog("【試合開始】");
        } else if (phase === 1) {
            clearInterval(timerInterval); phase = 2;
            btn.innerText = "後半開始"; btn.style.background = "var(--success)";
            document.getElementById('box1').classList.remove('active-timer');
            addLog("【ハーフタイム】");
        } else if (phase === 2) {
            startTimestamp = Date.now(); timerInterval = setInterval(updateTimer, 1000);
            phase = 3; btn.innerText = "ノーサイド"; btn.style.background = "#2c3e50";
            document.getElementById('box2').classList.add('active-timer');
            addLog("【後半開始】");
        } else if (phase === 3) {
            clearInterval(timerInterval); phase = 4;
            btn.style.display = "none"; document.getElementById('nextBtn').style.display = "block";
            document.getElementById('box2').classList.remove('active-timer');
            addLog("【ノーサイド】");
        }
    }

    function updateTimer() {
        let diff = Date.now() - startTimestamp;
        if (phase === 1) { t1 = diff; document.getElementById('time1').innerText = formatTime(t1); }
        else if (phase === 3) { t2 = diff; document.getElementById('time2').innerText = formatTime(t2); }
    }
    function formatTime(ms) { let s = Math.floor(ms / 1000); return `${String(Math.floor(s/60)).padStart(2,'0')}:${String(s%60).padStart(2,'0')}`; }

    function changeScore(team, pts, label) {
        const pKey = (phase <= 1) ? '1' : '2';
        const key = team + pKey;
        if (pts === -1) {
            let val = prompt("修正点数", scores[key]);
            if (val !== null) scores[key] = Number(val);
        } else {
            scores[key] += pts;
        }
        updateDisplay();
        addLog(`${document.getElementById('team'+team+'Name').value} ${label}更新`, null, team);
    }

    // Advなど、手書きメモを起動せず即座にカウント・ログ記録する関数
    function addDirectStat(team, type, label) {
        const pKey = (phase <= 1) ? '1' : '2';
        stats[team + pKey][type]++;
        updateDisplay();
        const teamLabel = document.getElementById('team' + team + 'Name').value;
        addLog(`【${teamLabel}】 ${label}`, null, team);
    }

    function updateDisplay() {
        document.getElementById('sA1').innerText = scores.A1;
        document.getElementById('sA2').innerText = scores.A2;
        document.getElementById('totalA').innerText = scores.A1 + scores.A2;
        document.getElementById('sB1').innerText = scores.B1;
        document.getElementById('sB2').innerText = scores.B2;
        document.getElementById('totalB').innerText = scores.B1 + scores.B2;

        ['A', 'B'].forEach(t => {
            ['1', '2'].forEach(p => {
                ['PK', 'FK', 'SC', 'LO', 'Adv'].forEach(s => {
                    document.getElementById(`s${t}${p}_${s}`).innerText = stats[`${t}${p}`][s];
                });
            });
        });
    }

    function addLog(msg, imgData = null, mode = "C") {
        const timeStr = (phase >= 3) ? `後${formatTime(t2)}` : `前${formatTime(t1)}`;
        const logObj = { id: Date.now(), time: timeStr, msg, imgData, mode };
        logs.push(logObj);
        renderLogs();
    }

    function renderLogs() {
        const area = document.getElementById('logArea');
        area.innerHTML = "";
        logs.slice().reverse().forEach(l => {
            const div = document.createElement('div');
            div.className = `log-entry log-${l.mode}`;
            div.innerHTML = `<b>[${l.time}] ${l.msg}</b>`;
            if (l.imgData) {
                div.innerHTML += `<img src="${l.imgData}" class="log-img">`;
                const ctrl = document.createElement('div');
                ctrl.className = 'log-controls';
                ctrl.innerHTML = `<button class="btn-edit" onclick="editLog(${l.id})">編集</button>`;
                div.appendChild(ctrl);
            }
            const delBtn = document.createElement('button');
            delBtn.className = 'btn-del';
            delBtn.style.position = 'absolute'; delBtn.style.right = '5px'; delBtn.style.bottom = '5px';
            delBtn.innerText = '削除';
            delBtn.onclick = () => deleteLog(l.id);
            div.appendChild(delBtn);
            area.appendChild(div);
        });
    }

    function deleteLog(id) {
        if(!confirm("このログを削除しますか？")) return;
        logs = logs.filter(l => l.id !== id);
        renderLogs();
    }

    // --- 描画 & スタッツ連動 ---
    const canvas = document.getElementById('drawingCanvas');
    const ctx = canvas.getContext('2d');
    let drawing = false;

    function openCanvasWithStat(team, type) {
        const pKey = (phase <= 1) ? '1' : '2';
        pendingStat = { teamKey: team + pKey, type, team };
        openCanvas(team, `${type} 記録`);
    }

    function editLog(id) {
        const log = logs.find(l => l.id === id);
        if(!log || !log.imgData) return;
        editingLogId = id;
        openCanvas(log.mode, "メモを編集");
        const img = new Image();
        img.onload = () => ctx.drawImage(img, 0, 0);
        img.src = log.imgData;
    }

    function openCanvas(mode, customTitle = null) {
        currentMode = mode;
        const name = (mode === 'A') ? document.getElementById('teamAName').value : (mode === 'B') ? document.getElementById('teamBName').value : "共通";
        document.getElementById('canvasTitle').innerText = customTitle || (name + " メモ");
        document.getElementById('canvasModal').style.display = 'flex';
        
        canvas.width = window.innerWidth; 
        canvas.height = (window.innerHeight * 0.5) - 40; 
        
        ctx.lineWidth = 3; ctx.lineCap = 'round';
        ctx.strokeStyle = (mode === 'A') ? '#3498db' : (mode === 'B') ? '#e74c3c' : '#333';
        clearCanvas();
        setupCanvasEvents();
    }

    function setupCanvasEvents() {
        const getP = e => {
            const r = canvas.getBoundingClientRect();
            const cx = e.touches ? e.touches[0].clientX : e.clientX;
            const cy = e.touches ? e.touches[0].clientY : e.clientY;
            return { x: cx - r.left, y: cy - r.top };
        };
        canvas.onpointerdown = e => { drawing = true; const p = getP(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); };
        canvas.onpointermove = e => { if (!drawing) return; const p = getP(e); ctx.lineTo(p.x, p.y); ctx.stroke(); };
        canvas.onpointerup = () => { drawing = false; };
    }

    function clearCanvas() { ctx.clearRect(0, 0, canvas.width, canvas.height); }
    function closeCanvas() { 
        document.getElementById('canvasModal').style.display = 'none'; 
        pendingStat = null; editingLogId = null; 
    }

    function saveCanvas() {
        const dataUrl = canvas.toDataURL();
        if (editingLogId) {
            const log = logs.find(l => l.id === editingLogId);
            if(log) log.imgData = dataUrl;
        } else if (pendingStat) {
            stats[pendingStat.teamKey][pendingStat.type]++;
            updateDisplay();
            const teamLabel = document.getElementById('team' + pendingStat.team + 'Name').value;
            addLog(`${teamLabel} ${pendingStat.type}発生`, dataUrl, pendingStat.team);
        } else {
            const teamLabel = (currentMode === 'A') ? document.getElementById('teamAName').value : (currentMode === 'B') ? document.getElementById('teamBName').value : "共通";
            addLog(`${teamLabel} メモ`, dataUrl, currentMode);
        }
        renderLogs();
        closeCanvas();
    }

    // --- CSV & 救出 ---
    function getCSV() {
        let csv = "\uFEFF時間,内容,A点,B点\n";
        logs.forEach(l => csv += `${l.time},"${l.msg}",${scores.A1+scores.A2},${scores.B1+scores.B2}\n`);
        return csv;
    }
    function downloadCSV() {
        const blob = new Blob([getCSV()], { type: 'text/csv' });
        const a = document.createElement('a'); a.href = URL.createObjectURL(blob);
        a.download = `RefLog_${Date.now()}.csv`; a.click();
    }
    function showBackup() {
        document.getElementById('backupText').value = getCSV();
        const imgContainer = document.getElementById('backupImages');
        imgContainer.innerHTML = '';
        logs.forEach(l => {
            if(l.imgData) {
                const wrap = document.createElement('div');
                wrap.innerHTML = `<p style="margin-bottom:0; font-size:0.8rem;">[${l.time}] ${l.msg}</p><img src="${l.imgData}" style="width:100%; border:1px solid #ccc; background:#fff; margin-bottom:10px;">`;
                imgContainer.appendChild(wrap);
            }
        });
        document.getElementById('backupModal').style.display = 'block';
    }
</script>
</body>
</html>
